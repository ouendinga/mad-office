# Mad Office Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to the repository

# Database password (required, use a strong random password)
DB_PASSWORD=

# JWT secret for authentication (required, min 32 chars, generate with: openssl rand -base64 48)
JWT_SECRET=

# Allowed origins for CORS (comma-separated, e.g. http://localhost:8081,https://yourdomain.com)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# Frontend API URLs (leave empty for same-origin via nginx proxy)
API_URL=
WS_URL=
